# Pathway Enrichment by KEGG using R
# Install BiocManager if you haven't already
if (!requireNamespace("BiocManager", quietly = TRUE))
  install.packages("BiocManager")

# Install clusterProfiler from Bioconductor
BiocManager::install("clusterProfiler",update = FALSE)
library(clusterProfiler)

BiocManager::install("org.Hs.eg.db",update = FALSE)
library(org.Hs.eg.db) # Assuming human sample data given the ENSG prefix

# Convert Ensembl IDs to Entrez IDs for KEGG compliance
gene_conversion <- bitr(spiking_genes$EnsemblID, 
                        fromType = "ENSEMBL", 
                        toType = "ENTREZID", 
                        OrgDb = org.Hs.eg.db)
# Check how many genes successfully converted
nrow(gene_conversion)

# Run the KEGG Pathway Enrichment Analysis
kegg_enrich <- enrichKEGG(gene         = gene_conversion$ENTREZID,
                          organism     = "hsa", # Human organism code
                          pvalueCutoff = 0.05,
                          pAdjustMethod = "BH")

# Look for your specific viral/cytokine terms in the output table
kegg_results <- as.data.frame(kegg_enrich)
print(head(kegg_results[, c("Description", "GeneRatio", "p.adjust")]))

# Plot the results to visualize the pathways
dotplot(kegg_enrich, showCategory = 15, title = "Upregulated Pathways During Peak Infection")

