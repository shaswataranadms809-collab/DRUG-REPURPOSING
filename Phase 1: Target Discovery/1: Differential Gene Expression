head (counts)
#Gene as serial no.s for DESeq2
head (counts)
rownames(counts) = counts$Gene
head (counts)
#Remove unused columns
genes = counts [,c("Gene","gene_name","gene_description")]
counts = counts [,-c(1,22,23)]
head(counts)

# Extract experimental factors from column names
# Columns look like "T_6h_016" -> Split by underscore
col_names_split <- strsplit(colnames(counts), "_")

condition <- sapply(col_names_split, function(x) x[1]) # Extracts 'T' or 'C'
time_point <- sapply(col_names_split, function(x) x[2]) # Extracts '6h' or '24h'

# Assemble into a clean colData data frame
colData <- data.frame(
  row.names = colnames(counts),
  condition = factor(condition, levels = c("C", "T")),       # Control as reference group
  time = factor(time_point, levels = c("6h", "24"))
)

# Preview it to make sure it aligns correctly
print(colData)

library(DESeq2)

# Create the DESeqDataSet using the interaction formula
dds <- DESeqDataSetFromMatrix(countData = counts,
                              colData = colData,
                              design = ~ time + condition + time:condition)

# Filter out lowly expressed genes (saves memory and boosts statistical power)
keep <- rowSums(counts(dds)) >= 10
dds <- dds[keep, ]

# Run the differential expression analysis
dds <- DESeq(dds)

# Check the specific name of the results coefficients generated by DESeq2
resultsNames(dds)

# To find genes upregulated in Treated vs Control at the 24h mark:
res_24h <- results(dds, contrast=c("condition", "T", "C")) 

# Apply log fold change shrinkage to clear up low-count noise
# (Note: 'coef' name must match one of the outputs from resultsNames(dds))

# Install BiocManager first (if you don't have it already)
if (!requireNamespace("BiocManager", quietly = TRUE))
  install.packages("BiocManager")

# Install the apeglm package
BiocManager::install("apeglm",update = FALSE)

library(apeglm)
res_LFC <- lfcShrink(dds, coef="condition_T_vs_C", type="apeglm")

# Convert to a data frame and pull out drastic high-spikers
library(tidyverse)
spiking_genes <- as.data.frame(res_LFC) %>%
  rownames_to_column(var = "EnsemblID") %>%
  filter(padj < 0.01 & log2FoldChange > 2) # Highly significant, >4-fold increase

print(head(spiking_genes))
